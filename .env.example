APP_NAME=ADAN
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://adan.test

FRONTEND_URL=http://localhost:5173

# --- Firebase (FCM) ---
# 1) Download a NEW service account key from Google Cloud (IAM → Keys). Never commit the JSON file.
# 2) Prefer storage/app/... (not web-served). If you use public/, keep the filename secret and rely on
#    public/.htaccess blocking firebase*.json over HTTP (Apache). Nginx: deny that location separately.
# FIREBASE_CREDENTIALS=storage/app/firebase-adminsdk.json
# FIREBASE_CREDENTIALS=public/firebase-adminsdk.json
# FIREBASE_CREDENTIALS=C:/secure/adan-service-account.json
FIREBASE_CREDENTIALS=
#
# 4) Web / Filament browser push: Firebase Console → Project settings → Your web app (copy config).
#    VAPID: same page area → Cloud Messaging → Web Push certificates → generate key pair.
# FIREBASE_WEB_API_KEY=
# FIREBASE_WEB_AUTH_DOMAIN=
# FIREBASE_WEB_PROJECT_ID=
# FIREBASE_WEB_STORAGE_BUCKET=
# FIREBASE_WEB_MESSAGING_SENDER_ID=
# FIREBASE_WEB_APP_ID=
# FIREBASE_WEB_MEASUREMENT_ID=
# FIREBASE_WEB_VAPID_KEY=
#
# After editing: php artisan config:clear && php artisan firebase:verify

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
