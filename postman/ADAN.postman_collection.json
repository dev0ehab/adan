                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"animal_id\": 1,\n  \"nickname\": \"Bella\",\n  \"birth_date\": \"2023-01-15\",\n  \"last_vaccine_date\": null,\n  \"notes\": null\n}"
