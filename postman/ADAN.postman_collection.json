{
    "info": {
        "_postman_id": "c4a8e2b1-9f3d-4e7c-a1b2-3d4e5f607890",
        "name": "ADAN API",
        "description": "Animal Disease Alert Network — REST API collection.\n\n**Setup:** Import this file in Postman, set collection variables `base_url` (e.g. `http://localhost:8000/api`) and `token` (paste the `token` value from **Auth → Login**).\n\nAuthenticated requests use Bearer auth from `{{token}}`.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{token}}",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000/api"
        },
        {
            "key": "token",
            "value": ""
        },
        {
            "key": "country_id",
            "value": "1"
        },
        {
            "key": "governorate_id",
            "value": "1"
        },
        {
            "key": "city_id",
            "value": "1"
        },
        {
            "key": "category_id",
            "value": "1"
        },
        {
            "key": "animal_id",
            "value": "1"
        },
        {
            "key": "user_animal_id",
            "value": "1"
        },
        {
            "key": "schedule_id",
            "value": "1"
        },
        {
            "key": "report_id",
            "value": "1"
        },
        {
            "key": "notification_id",
            "value": "1"
        }
    ],
    "item": [
        {
            "name": "System",
            "item": [
                {
                    "name": "Health",
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "GET",
                        "header": [],
                        "url": "{{base_url}}/health"
                    }
                }
            ]
        },
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"phone\": \"+201000000000\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"region_id\": null\n}"
                        },
                        "url": "{{base_url}}/auth/register"
                    }
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.token) {",
                                    "  pm.collectionVariables.set('token', json.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"customer@adan.com\",\n  \"password\": \"password\"\n}"
                        },
                        "url": "{{base_url}}/auth/login"
                    }
                },
                {
                    "name": "Send OTP",
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"phone\": \"+201000000000\"\n}"
                        },
                        "url": "{{base_url}}/auth/send-otp"
                    }
                },
                {
                    "name": "Verify OTP",
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"phone\": \"+201000000000\",\n  \"otp\": \"000000\"\n}"
                        },
                        "url": "{{base_url}}/auth/verify-otp"
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/auth/logout"
                    }
                },
                {
                    "name": "Me",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/auth/me"
                    }
                }
            ]
        },
