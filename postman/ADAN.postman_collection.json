                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"animal_id\": 1,\n  \"region_id\": 1,\n  \"title\": \"Observed symptoms in herd\",\n  \"description\": \"Detailed description of at least twenty characters for validation.\",\n  \"severity\": \"moderate\",\n  \"latitude\": 30.0444,\n  \"longitude\": 31.2357\n}"
                        },
                        "url": "{{base_url}}/reports",
                        "description": "API validates `images` as multipart files. For uploads, duplicate this request, set body to **form-data**, add fields `animal_id`, `region_id`, `title`, `description`, `severity`, optional `latitude`/`longitude`, and `images` as file type."
                    }
                },
